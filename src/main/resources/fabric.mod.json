{
	"schemaVersion": 1,
	"id": "dogecoin",
	"version": "${version}",
	"name": "Dogecoin mod",
	"description": "Adds Dogecoin to Minecraft — feed gold to a wolf, use the ATM wallet!",
	"authors": ["Yel0w!"],
	"contact": {
		"homepage": "https://github.com/Yel0w08/Dogecoin-Mod-FabricMC/wiki",
		"sources": "https://github.com/Yel0w08/Dogecoin-Mod-FabricMC"
	},
	"license": "MIT",
	"icon": "assets/dogecoin/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": ["com.pikmintea.dogecoin.Dogecoin"],
		"fabric-datagen": ["com.pikmintea.dogecoin.DogecoinDataGenerator"],
		"client": ["com.pikmintea.dogecoin.DogecoinClient"]
	},
	"depends": {
		"fabricloader": "${loader_dep}",
		"minecraft": "${minecraft_dep}",
		"java": "${java_dep}",
		"fabric-api": "*"
